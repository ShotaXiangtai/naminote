{
  "name": "naminote",
  "version": "1.0.0",
  "description": "勉強特化のページ制ノートソフト",
  "main": "main.js",
  "author": "naminote",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "app.naminote",
    "productName": "naminote",
    "directories": {
      "output": "C:/naminote_dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["ja-JP"],
      "language": "1041",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "naminote"
    },
    "portable": {
      "artifactName": "naminote-portable.exe"
    }
  }
}
